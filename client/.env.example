# Origin of the Express API. Used by BOTH the axios instance and better-auth
# (they share API_BASE_URL from src/configs/axios.ts), so they must point at the
# same host or the session cookie is set on one origin and read from another.
#
# No trailing slash. Defaults to http://localhost:3000 when unset.
#
# Local:      http://localhost:3000
# Production: https://your-api.onrender.com
#
# On Vercel this is set under Settings -> Environment Variables, NOT in a file.
# Vite inlines VITE_* at BUILD time, so changing it requires a redeploy, and
# whatever value you set must also appear in the server's TRUSTED_ORIGINS
# (the reverse direction) or every request fails CORS.
VITE_BASEURL="http://localhost:3000"

# ============================================================
# Global .gitignore for the whole repo (client/ + server/)
# The per-package client/.gitignore and server/.gitignore were
# consolidated here — keep new rules in this file only.
# ============================================================

# dependencies
node_modules/

# environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# generated code (prisma client output — see server/prisma/schema.prisma)
server/generated/
generated/prisma/

# logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# build folders
dist/
dist-ssr/
build/
.next/
out/

# coverage
coverage/

# cache
.cache/
.parcel-cache/
.vite/

# OS files
.DS_Store
Thumbs.db

# IDE / editors
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# typescript
*.tsbuildinfo

# AI assistant notes
CLAUDE.md

# misc
*.zip
*.tar
*.gz

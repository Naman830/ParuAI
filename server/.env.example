# Comma-separated list of allowed origins. Feeds both CORS and better-auth.
TRUSTED_ORIGINS="http://localhost:5173"

# Postgres / Neon connection string.
DATABASE_URL="NEON DATABASE"

# better-auth signing secret (generate a long random string).
BETTER_AUTH_SECRET=""

# Public base URL of THIS API. Must match the client's VITE_BASEURL.
BETTER_AUTH_URL="http://localhost:3000"

# "production" switches the session cookie to secure + sameSite=none.
NODE_ENV="development"

# OpenRouter API key (the OpenAI SDK is pointed at openrouter.ai).
AI_API_KEY=""

# Optional. Generation model, and the pause before the first completion that
# works around OpenRouter free-tier rate limits (set to 0 on a paid key).
AI_MODEL="stepfun/step-3.5-flash:free"
AI_RATE_LIMIT_DELAY_MS="4000"

# Optional. Defaults to 3000.
PORT="3000"

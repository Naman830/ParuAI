# Copy to .env and fill in real values. NEVER commit .env.
# Every key below is read in server/configs/openai.ts, server/lib/auth.ts,
# server/lib/prisma.ts or server.ts.

# ---- Database ----
# Postgres / Neon connection string. Used by the Prisma client and
# prisma.config.ts. Use the POOLED (-pooler) host for a long-running server.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Auth ----
# better-auth signing secret. Generate with: openssl rand -base64 32
# Changing it invalidates every existing session.
BETTER_AUTH_SECRET=""

# Public base URL of THIS API — no trailing slash.
# Local: http://localhost:3000   Production: https://your-api.onrender.com
BETTER_AUTH_URL="http://localhost:3000"

# Comma-separated origins of the FRONTEND. Feeds both CORS (server.ts) and
# better-auth trustedOrigins (lib/auth.ts); both trim whitespace, but keep it
# tidy. No trailing slashes. Leave this empty and every browser request 403s.
# Production example:
#   TRUSTED_ORIGINS="https://paruai.vercel.app,https://www.paruai.com"
TRUSTED_ORIGINS="http://localhost:5173"

# "production" switches the session cookie to secure + sameSite=none, which is
# REQUIRED when the client and API sit on different domains (Vercel + Render).
# It also means the cookie is dropped over plain http — keep "development"
# locally. Most hosts set this for you; set it explicitly to be sure.
NODE_ENV="development"

# API key for the hosted Better Auth dashboard (https://dash.better-auth.com),
# in the form ba_… . Read straight out of the environment by the dash() plugin
# in lib/auth.ts — the plugin call passes no apiKey, so THIS NAME is the wiring.
# Optional: leave it empty and auth works exactly as before, just without the
# dashboard connection.
BETTER_AUTH_API_KEY=""

# ---- AI (OpenRouter) ----
# OpenRouter API key (the OpenAI SDK is pointed at openrouter.ai/api/v1).
# Get one at https://openrouter.ai/keys
AI_API_KEY=""

# Optional. Generation model; defaults to poolside/laguna-s-2.1:free, which was
# measured at ~37-72s for a full page and does return raw un-fenced HTML.
#
# Free-tier slugs get withdrawn without notice and are rate-limited under load
# (OpenRouter answers 429 "temporarily rate-limited upstream"). When every
# generation starts failing, check the key and the slug FIRST:
#   curl -s https://openrouter.ai/api/v1/models | grep -o '"id":"[^"]*:free"'
#
# Other free slugs verified to return clean HTML for this prompt:
#   nvidia/nemotron-3-super-120b-a12b:free
#   cohere/north-mini-code:free
#   openai/gpt-oss-20b:free
# A paid key and a stronger model give markedly better sites and far fewer 429s.
AI_MODEL="poolside/laguna-s-2.1:free"

# Optional. Pause before the first completion, to dodge free-tier rate limits.
# Set to 0 on a paid key.
AI_RATE_LIMIT_DELAY_MS="4000"

# Optional. Per-request ceiling, default 300000 (5 min), and retry count,
# default 2. Generation on a free model really can take minutes, so keep this
# generous; it only bounds the hang case. Without a bound, a stalled provider
# leaves the project at current_code: null with no [generation-failed] marker
# and the client polls forever.
AI_REQUEST_TIMEOUT_MS="300000"
AI_MAX_RETRIES="2"

# ---- Server ----
# Optional. Defaults to 3000. Render/Railway inject their own PORT — do not
# hardcode it there.
PORT="3000"

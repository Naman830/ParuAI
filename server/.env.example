# Copy to .env and fill in real values. NEVER commit .env.
# Every key below is read in server/configs/openai.ts, server/lib/auth.ts,
# server/lib/prisma.ts or server.ts.

# ---- Database ----
# Postgres / Neon connection string. Used by the Prisma client and
# prisma.config.ts. Use the POOLED (-pooler) host for a long-running server.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Auth ----
# better-auth signing secret. Generate with: openssl rand -base64 32
# Changing it invalidates every existing session.
BETTER_AUTH_SECRET=""

# Public base URL of THIS API — no trailing slash.
# Local: http://localhost:3000   Production: https://your-api.onrender.com
BETTER_AUTH_URL="http://localhost:3000"

# Comma-separated origins of the FRONTEND. Feeds both CORS (server.ts) and
# better-auth trustedOrigins (lib/auth.ts); both trim whitespace, but keep it
# tidy. No trailing slashes. Leave this empty and every browser request 403s.
# Production example:
#   TRUSTED_ORIGINS="https://paruai.vercel.app,https://www.paruai.com"
TRUSTED_ORIGINS="http://localhost:5173"

# "production" switches the session cookie to secure + sameSite=none, which is
# REQUIRED when the client and API sit on different domains (Vercel + Render).
# It also means the cookie is dropped over plain http — keep "development"
# locally. Most hosts set this for you; set it explicitly to be sure.
NODE_ENV="development"

# ---- AI (OpenRouter) ----
# OpenRouter API key (the OpenAI SDK is pointed at openrouter.ai/api/v1).
# Get one at https://openrouter.ai/keys
AI_API_KEY=""

# Optional. Generation model; defaults to poolside/laguna-s-2.1:free.
# Free-tier model slugs get withdrawn without notice — when every generation
# starts failing, check the key and the slug FIRST:
#   curl https://openrouter.ai/api/v1/models | grep ':free'
AI_MODEL="poolside/laguna-s-2.1:free"

# Optional. Pause before the first completion, to dodge free-tier rate limits.
# Set to 0 on a paid key.
AI_RATE_LIMIT_DELAY_MS="4000"

# ---- Server ----
# Optional. Defaults to 3000. Render/Railway inject their own PORT — do not
# hardcode it there.
PORT="3000"
